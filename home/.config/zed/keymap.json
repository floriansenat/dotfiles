// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "space space": "tab_switcher::Toggle",
      "space s f": "file_finder::Toggle",
      "space z k": "zed::OpenKeymapFile",
      "space z s": "zed::OpenSettingsFile",
      "space z x": "zed::Extensions",
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space q a": "pane::CloseAllItems",
      "space b k": "workspace::CloseInactiveTabsAndPanes",
      "space b q": "pane::CloseActiveItem",
      "space g b": "git::Blame",
      "space a": "agent::ToggleFocus",
      "space o": "outline::Toggle",
      "space w": "workspace::Save",
      "space x": [
        "action::Sequence",
        ["workspace::Save", "pane::CloseActiveItem"],
      ],
      "space c": [
        "action::Sequence",
        ["workspace::CloseAllDocks", "workspace::ToggleCenteredLayout"],
      ],
    },
  },
]
