theme = dark:Everforest Dark Hard,light:Everforest Light Med

# font-family = Departure Mono
font-family = Zed Mono Extended
font-size = 15
adjust-cell-height = 18
unfocused-split-opacity = 1
macos-titlebar-style = hidden
window-padding-x = 12
window-padding-y = 12
window-save-state = always
auto-update = download
shell-integration = zsh

# Splits
keybind = opt+space>h=new_split:left
keybind = opt+space>l=new_split:right
keybind = opt+space>k=new_split:up
keybind = opt+space>j=new_split:down

keybind = shift+escape=toggle_split_zoom
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+k=goto_split:top

# Other
keybind = opt+space>c=open_config
keybind = opt+space>r=reload_config
keybind = global:cmd+escape=toggle_quick_terminal
